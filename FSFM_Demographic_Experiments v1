        "val_ff_4   = torch.load(f'{DEMO_CACHE}/fairface_val_4class.pt',\n",
        "                         weights_only=False)\n",
        "train_ff_4 = remap_ages(train_ff_4, AGE_TO_3CLASS)\n",
        "val_ff_4   = remap_ages(val_ff_4,   AGE_TO_3CLASS)\n",
        "\n",
